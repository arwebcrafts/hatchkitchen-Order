# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY

# Silent owner order alerts (customer never sees / receives this)
OWNER_EMAIL=info@thehatchkitchen.com

# SMTP (like PHP mail) — required for owner alerts on Vercel
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@thehatchkitchen.com
SMTP_PASS=your-app-password
# SMTP_FROM=Hatch Kitchen Orders <info@thehatchkitchen.com>
